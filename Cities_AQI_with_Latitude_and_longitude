        "outputId": "6843844e-a5c5-442c-bdb7-1e4ea46384ae"
      },
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Create a DataFrame for new hypothetical cities, aligning features with the trained model\n",
        "new_cities_data = {\n",
        "    'city': ['Hypothetical City A', 'Hypothetical City B', 'Hypothetical City C', 'Hypothetical City D', 'Hypothetical City E'],\n",
        "    'pollutant_min': [70, 30, 120, 50, 90],  # Using pm25 as a proxy for pollutant_min\n",
        "    'pollutant_max': [110, 60, 180, 80, 150], # Using pm10 as a proxy for pollutant_max\n",
        "    'latitude_y': [28.6, 22.3, 34.0, 19.1, 30.5], # Using latitude for latitude_y\n",
        "    'longitude_y': [77.2, 70.0, 118.2, 72.8, 76.8] # Using longitude for longitude_y\n",
        "}\n",
        "\n",
        "new_cities_df = pd.DataFrame(new_cities_data)\n",
        "display(new_cities_df.head())\n",
        "\n",
        "# Select the same features used for training the model\n",
        "X_new_cities = new_cities_df[features]\n",
        "\n",
        "# Predict AQI for the new cities\n",
        "new_cities_df['Predicted_AQI'] = model.predict(X_new_cities)\n",
        "\n",
        "print(\"\\nPredicted AQI for New Cities:\")\n",
        "display(new_cities_df[['city', 'Predicted_AQI']])"
      ],
