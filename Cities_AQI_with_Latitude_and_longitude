      "source": [
        "# =========================\n",
        "# INSTALL & IMPORT\n",
        "# =========================\n",
        "!pip -q install pandas scikit-learn matplotlib\n",
        "\n",
        "import pandas as pd\n",
        "import zipfile\n",
        "import matplotlib.pyplot as plt\n",
        "import os\n",
        "\n",
        "# =========================\n",
        "# UPLOAD & EXTRACT (Assuming zip files are already uploaded in Colab session)\n",
        "# =========================\n",
        "# If files are not uploaded yet, uncomment the lines below and run the cell to upload them:\n",
        "# from google.colab import files\n",
        "# uploaded = files.upload()\n",
        "\n",
        "# Ensure 'data' directory exists\n",
        "os.makedirs('data', exist_ok=True)\n",
        "\n",
        "zip_files = [\n",
        "    \"AQI-Benford-s-Law-Analysis-Project-main.zip\",\n",
        "    \"Indian-city-geodata-main.zip\",\n",
        "    \"weather-by-city-India-main.zip\"\n",
        "]\n",
        "\n",
        "for file in zip_files:\n",
        "    if os.path.exists(file):\n",
        "        with zipfile.ZipFile(file, 'r') as zip_ref:\n",
        "            zip_ref.extractall(\"data\")\n",
        "\n",
        "# =========================\n",
        "# DEBUG: LIST DIRECTORY CONTENTS (Keeping these lines for initial verification)\n",
        "# =========================\n",
        "print(\"Contents of 'data/' directory:\")\n",
        "print(os.listdir('data'))\n",
        "print(\"\\nContents of 'data/AQI-Benford-s-Law-Analysis-Project-main/' directory:\")\n",
        "print(os.listdir('data/AQI-Benford-s-Law-Analysis-Project-main'))\n",
        "print(\"\\nContents of 'data/Indian-city-geodata-main/' directory:\")\n",
        "print(os.listdir('data/Indian-city-geodata-main'))\n",
        "print(\"\\nContents of 'data/weather-by-city-India-main/' directory:\")\n",
        "print(os.listdir('data/weather-by-city-India-main'))\n",
        "# Adding listdir for nested weather data folder to confirm path\n",
        "print(\"\\nContents of 'data/weather-by-city-India-main/data/' directory:\")\n",
        "if os.path.exists('data/weather-by-city-India-main/data/'):\n",
        "    print(os.listdir('data/weather-by-city-India-main/data/'))\n",
        "else:\n",
        "    print(\"Nested 'data' directory not found for weather.\")\n",
        "\n",
        "# =========================\n",
        "# LOAD DATA\n",
        "# =========================\n",
        "aqi = pd.read_csv(\"data/AQI-Benford-s-Law-Analysis-Project-main/air_quality_index_of_indian_cities.csv\")\n",
        "geo = pd.read_json(\"data/Indian-city-geodata-main/cities.json\") # Changed to read_json\n",
        "# weather data is not found, so we'll proceed without it\n",
        "# weather = pd.read_csv(\"data/weather-by-city-India-main/data/weather.csv\")\n",
        "\n",
        "# =========================\n",
        "# CLEAN + MERGE\n",
        "# =========================\n",
        "aqi.columns = aqi.columns.str.lower()\n",
        "geo.columns = geo.columns.str.lower()\n",
        "# weather.columns = weather.columns.str.lower() # No weather data to clean\n",
        "\n",
        "aqi.rename(columns={\"city_name\": \"city\"}, inplace=True, errors=\"ignore\")\n",
        "\n",
        "df = aqi.merge(geo, on=\"city\", how=\"left\") \\\n",
        "        .dropna()\n",
        "\n",
        "print(\"\\nColumns of the merged DataFrame (df) before AQI calculation:\")\n",
        "print(df.columns)\n",
        "\n",
        "# =========================\n",
        "# AQI CALCULATION\n",
        "# =========================\n",
        "# The original formula used 'pm25' and 'pm10' which are not directly available.\n",
        "# Assuming 'pollutant_avg' is the target AQI or a proxy for it, as 'pollutant_id' column likely differentiates pollutants.\n",
        "# If a specific AQI formula is needed based on multiple pollutant types (e.g., PM2.5, PM10),\n",
        "# further data transformation based on 'pollutant_id' would be required.\n",
        "# For now, we will use 'pollutant_avg' directly as the target 'AQI'.\n",
        "df['AQI'] = df['pollutant_avg']\n",
        "\n",
        "# =========================\n",
        "# STATUS CLASSIFICATION\n",
        "# =========================\n",
        "def classify(aqi):\n",
        "    if aqi <= 50: return \"GOOD\"\n",
        "    elif aqi <= 100: return \"MODERATE\"\n",
        "    elif aqi <= 150: return \"UNHEALTHY\"\n",
        "    else: return \"DANGER\"\n",
        "\n",
        "df['Status'] = df['AQI'].apply(classify)\n",
        "\n",
        "# =========================\n",
        "# ML MODEL SETUP\n",
        "# =========================\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "\n",
        "# Features are updated to use available pollutant and geographic columns.\n",
        "# 'pollutant_avg' is used as the target (y).\n",
        "features = ['pollutant_min', 'pollutant_max', 'latitude_y', 'longitude_y']\n",
        "\n",
        "X = df[features]\n",
        "y = df['AQI']\n",
        "\n",
        "# Initialize and fit the model on the entire dataset\n",
        "model = RandomForestRegressor(n_estimators=50, random_state=42)\n",
        "model.fit(X, y)\n",
        "\n",
        "# =========================\n",
        "# SAVE OUTPUT\n",
        "# =========================\n",
        "df.to_csv(\"report.csv\", index=False)\n",
        "\n",
        "# =========================\n",
        "# VISUALIZATION\n",
        "# =========================\n",
        "plt.plot(df['AQI'])\n",
        "plt.title(\"AQI Trend\")\n",
        "plt.show()"
      ],
